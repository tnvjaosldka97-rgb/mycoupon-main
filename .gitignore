.vercel/

# Android build output (바이너리/생성물만 제외, 소스는 추적)
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/local.properties
android/gradle/wrapper/gradle-wrapper.jar
# google-services.json은 민감 정보 포함 가능 (수동 배치)
android/app/google-services.json

# Drizzle migration SQL
drizzle/*.sql

# Android signing key (sensitive)
*.keystore
*.jks
# 키스토어 자격증명 파일 (비밀번호 등)
android/keystore.properties

# apps/mobile — DEPRECATED (React Native 경로 폐기)
# Capacitor Android(android/)이 유일한 모바일 제품.
apps/mobile/.expo/
apps/mobile/*.txt
apps/mobile/app.json
apps/mobile/metro.config.js

# Firebase Admin SDK service account credentials (NEVER commit)
firebase-adminsdk-*.json
*firebase*service*account*.json
