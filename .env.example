# ====================================================
# MyCoupon 환경변수 템플릿 (.env.example)
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
# 실제 값이 담긴 .env 파일은 절대 git에 커밋하지 마세요.
# ====================================================

# ── 데이터베이스 (필수) ──────────────────────────────
# Railway PostgreSQL > Connect에서 확인
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── 인증/JWT (필수 - 반드시 강력한 랜덤 문자열 사용) ──
# 생성 방법: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-random-secret-here-minimum-32-chars

# ── Google OAuth (필수) ──────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 확인
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth 리다이렉트 URI (기본값: 프로덕션 URL)
# 웹: https://my-coupon-bridge.com/api/oauth/google/callback
# Google Cloud Console에 등록된 값과 정확히 일치해야 함
GOOGLE_OAUTH_REDIRECT_URI=https://my-coupon-bridge.com/api/oauth/google/callback

# ── Google Maps API (프론트 빌드 시 필요) ────────────
# Google Cloud Console > Maps JavaScript API 키
# Vite 빌드 타임에만 사용됨 (서버 런타임 불필요)
VITE_FRONTEND_FORGE_API_KEY=your-google-maps-api-key

# ── 서버 URL ────────────────────────────────────────
OAUTH_SERVER_URL=https://my-coupon-bridge.com
NEXTAUTH_URL=https://my-coupon-bridge.com
MYCOUPON_SERVER_URL=https://my-coupon-bridge.com

# ── 이메일 발송 (선택 - Gmail SMTP) ─────────────────
# Gmail > 앱 비밀번호에서 생성 (2단계 인증 필요)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── 관리자 설정 ─────────────────────────────────────
# 슈퍼어드민 이메일 (쉼표로 구분, 1개 권장)
MASTER_ADMIN_EMAILS=tnvjaosldka97@gmail.com

# ── Railway 브릿지 서버 (선택) ───────────────────────
BRIDGE_SECRET=your-bridge-secret
BRIDGE_SERVER_URL=https://your-bridge-server.com

# ── 앱 ID (Vite 빌드용) ─────────────────────────────
VITE_APP_ID=com.mycoupon.app
