<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 네트워크 권한 (API 통신) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 위치 권한 (쿠폰 지도 기능) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 알림 권한 (Android 13+ API 33 필수 — 없으면 FCM 푸시 수신 불가) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 배터리 최적화 제외 권한 (카톡/네이버/배민 패턴) -->
    <!-- 안드로이드 OEM 의 aggressive battery optimization 이 background FCM push 를 silent 처리하는 것 방지 -->
    <!-- 첫 실행 시 시스템 다이얼로그로 사용자에게 자동 요청 → "허용" 클릭 시 영구 제외 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 카메라 권한 (PR-49 사장님 쿠폰 QR 스캔 — html5-qrcode + Capacitor) -->
    <!-- 사장님이 사용자 폰의 쿠폰 QR 코드를 스캔하여 사용 처리 (PIN 입력 fallback 동시 제공) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- PR-58: 백그라운드 위치 추적 (사용자 앱 minimized 상태에서도 GPS, 사장님 명시) -->
    <!-- ACCESS_BACKGROUND_LOCATION: Android 10+ 백그라운드 위치 접근 -->
    <!-- FOREGROUND_SERVICE + FOREGROUND_SERVICE_LOCATION: 영구 알림 + Android 14+ foreground service type -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- PR-62: OS 보호 강화 (사장님 명시 — 앱 꺼도 GPS 따라다님) -->
    <!-- WAKE_LOCK: CPU wake up 유지 (ForegroundService 안정성 ↑) -->
    <!-- RECEIVE_BOOT_COMPLETED: 폰 재부팅 후 자동 service 재시작 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- TODO: ic_launcher PNG 준비 후 @mipmap/ic_launcher 로 교체 -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="false"
        android:forceDarkAllowed="false"
        tools:targetApi="34">
        <!-- android:forceDarkAllowed="false":
             Android 10(API 29)+ 에서 시스템 다크모드가 켜져 있을 때
             Android OS가 WebView 콘텐츠에 강제로 색상 반전을 적용하는 것을 방지.
             이것이 앱이 과도하게 어둡게 보이는 주요 원인. -->

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:exported="true"
            android:launchMode="singleTask"
            android:name=".MainActivity"
            android:theme="@style/AppTheme.NoActionBarLaunch">

            <!-- 앱 진입점 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ⚠️ HTTPS App Links 제거됨 — OAuth callback hijack 방지 -->
            <!-- 이전에는 host="my-coupon-bridge.com" 전체를 autoVerify로 잡아서
                 Google OAuth callback(https://my-coupon-bridge.com/api/oauth/google/callback?code=...)
                 까지 Android가 앱으로 가로챔 → 서버가 app_ticket을 발급하기 전에
                 앱이 raw callback URL을 수신 → extractAppTicket 실패 → exchange_not_called.
                 단일 계약: mycoupon://auth?app_ticket=... (custom scheme only) 로 강제. -->

            <!-- 단일 계약: mycoupon://auth?app_ticket=<token> -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:host="auth"
                    android:scheme="mycoupon" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- FCM background push 가 사용할 default notification channel id.
             누락 시 Android 8+ 에서 channel 미명시 push 가 일부 디바이스에서 silent. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="default" />
    </application>
</manifest>
