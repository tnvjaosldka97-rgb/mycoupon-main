<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 기본 앱 테마 -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#FF9800</item>
        <item name="colorPrimaryDark">#E65100</item>
        <item name="colorAccent">#FF9800</item>
        <!-- forceDarkAllowed="false": Android 10+ 강제 다크모드 적용 차단 -->
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <!-- 스플래시/런치 테마 (ActionBar 없음) -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFF5F0</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#FF9800</item>
        <item name="colorPrimaryDark">#E65100</item>
        <item name="colorAccent">#FF9800</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Chrome Custom Tabs 닫힐 때 앱 전환 애니메이션 중 검정 배경 차단 -->
        <item name="android:windowBackground">@android:color/white</item>
        <!-- 상태바 배경도 앱 테마 색상으로 통일 -->
        <item name="android:statusBarColor">#FFF5F0</item>
    </style>
</resources>
